"""The document shell — a combinator: it pours the page around fragments."""

from camber import Element
from camber import html as h


def shell(*fragments: Element) -> Element:
    return h.html(
        h.head(
            h.meta(charset="utf-8"),
            h.meta(name="viewport", content="width=device-width, initial-scale=1"),
            h.title("__CAMBER_TITLE__"),
            h.style_link("/static/tarmac.css"),
            h.script(src="/static/lib/camber.js"),
        ),
        h.body(
            h.header(h.h1("__CAMBER_TITLE__")),
            h.main(*fragments),
            data_boost=True,
        ),
        lang="en",
    )
