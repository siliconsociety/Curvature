"""__CURVATURE_TITLE__ — assembled the curved way.

Reads render through respond(); writes go POST -> redirect -> GET.
Run it: ./run.sh
"""

from pathlib import Path

from fastapi import FastAPI, Request
from fastapi.staticfiles import StaticFiles

import curvature
from curvature import respond

from app.components.shell import shell
from app.components.welcome import WelcomeProps, welcome

app = FastAPI(title="__CURVATURE_TITLE__")
app.mount("/static/lib", StaticFiles(directory=Path(curvature.__file__).parent / "static"))
app.mount("/static", StaticFiles(directory=Path(__file__).parent / "static"))


@app.get("/")
async def index(request: Request):
    return respond(request, welcome(WelcomeProps(app_name="__CURVATURE_TITLE__")), shell=shell)
